# SelfHeal Environment Configuration
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------
# LLM Configuration
# ---------------------------------------------------------
# Provider can be 'nim' or 'ollama'
SELFHEAL_LLM_PROVIDER=nim

# NVIDIA NIM Config
SELFHEAL_NIM_API_KEY=your_nim_api_key_here
SELFHEAL_NIM_MODEL=meta/llama-3.3-70b-instruct
SELFHEAL_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Ollama Config (Local)
SELFHEAL_OLLAMA_MODEL=llama3.2
SELFHEAL_OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------
# Calendar Integrations
# ---------------------------------------------------------
# CalDAV Config (e.g. Nextcloud, Apple, Fastmail)
SELFHEAL_CALDAV_URL=https://caldav.example.com/
SELFHEAL_CALDAV_USERNAME=your_username
SELFHEAL_CALDAV_PASSWORD=your_app_password

# ClickUp Config
SELFHEAL_CLICKUP_API_TOKEN=pk_your_clickup_token_here
SELFHEAL_CLICKUP_LIST_ID=your_clickup_list_id_here

# ---------------------------------------------------------
# Integrations
# ---------------------------------------------------------
# Obsidian Vault Path (for daily notes sync)
SELFHEAL_OBSIDIAN_VAULT_PATH=~/Documents/Obsidian

# Wallpaper Integration (exports schedule to JSON for KDE/etc)
SELFHEAL_WALLPAPER_ENABLED=true
SELFHEAL_WALLPAPER_INTERVAL=60

# ---------------------------------------------------------
# Daemon Configuration
# ---------------------------------------------------------
# Directories (Optional overrides)
# SELFHEAL_CONFIG=~/.config/selfheal
# SELFHEAL_DATA=~/.local/share/selfheal
