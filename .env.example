# SelfHeal Environment Configuration
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------
# LLM Configuration
# ---------------------------------------------------------
# Providers: 'anthropic', 'openai', 'nim', 'ollama'
SELFHEAL_LLM_PROVIDER=anthropic

# Anthropic (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI (GPT-4o)
OPENAI_API_KEY=your_openai_key_here

# NVIDIA NIM Config
NVIDIA_API_KEY=your_nim_api_key_here
SELFHEAL_NIM_MODEL=meta/llama-3.3-70b-instruct

# Ollama Config (Local)
SELFHEAL_OLLAMA_MODEL=llama3.2
SELFHEAL_OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------
# Integrations
# ---------------------------------------------------------
# ClickUp Config
SELFHEAL_CLICKUP_API_TOKEN=pk_your_clickup_token_here
SELFHEAL_CLICKUP_LIST_ID=your_clickup_list_id_here

# Obsidian Vault Path
SELFHEAL_OBSIDIAN_VAULT_PATH=~/Documents/Obsidian

# ---------------------------------------------------------
# App Configuration
# ---------------------------------------------------------
SELFHEAL_DAEMON_PORT=8282
SELFHEAL_DASHBOARD_URL=http://localhost:3000
